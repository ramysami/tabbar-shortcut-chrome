{
  "manifest_version": 3,
  "name": "Toggle Vertical Tabs",
  "description": "Keyboard shortcut to toggle Chrome's native vertical tab bar",
  "version": "1.0",
  "permissions": [
    "nativeMessaging"
  ],
  "commands": {
    "toggle-vertical-tabs": {
      "suggested_key": {
        "default": "Ctrl+S",
        "mac": "Ctrl+S"
      },
      "description": "Toggle vertical tab bar"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}